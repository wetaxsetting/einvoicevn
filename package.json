    "description": "The fullstack application boilerplate for Adonisjs",
    "main": "index.js",
    "scripts": {
        "ok": "nodemon --watch app --watch config --watch start --watch .env -x node --max-old-space-size=16384 server.js",
        "dev": "nodemon --watch app --watch config --watch start --watch .env -x node --openssl-legacy-provider --max-old-space-size=16384 server.js",
        "start": "set NODE_ENV=production node server.js",
        "build": "adonis nuxt:build",
        "test": "node ace test",
        "devlocal": "nodemon --watch app --watch config --watch start --watch .env -x node --max-old-space-size=16384 server.js"
    },
